# GDEX Environment Variables
# Copy this file to .env.local for local development
# For Vercel, add these as environment variables in your project settings

# Optional: Custom GD server secret (base64 encoded for security)
# Default: Wmfd2893gb7 (encoded: V21mZDI4OTNnYjc=)
# To encode: echo -n "your_secret" | base64
# GD_SECRET=V21mZDI4OTNnYjc=

# Optional: Maximum allowed level ID (default: 999999999)
# MAX_LEVEL_ID=999999999
